{
  "name": "cf-worker-redmine-replacement",
  "version": "0.1.0",
  "private": true,
  "description": "Redmine-style project management built on TanStack Start + TanStack Router, deployed on Cloudflare Workers.",
  "type": "module",
  "scripts": {
    "dev": "vinxi dev",
    "build": "vinxi build",
    "start": "vinxi start",
    "preview": "wrangler dev .output/server/index.mjs --site .output/public --compatibility-date 2026-01-01",
    "deploy": "npm run build && wrangler deploy .output/server/index.mjs --site .output/public",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply redmine --local",
    "db:migrate": "wrangler d1 migrations apply redmine --remote",
    "db:seed:local": "wrangler d1 execute redmine --local --file=./drizzle/seed.sql",
    "db:seed": "wrangler d1 execute redmine --remote --file=./drizzle/seed.sql",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.95.1",
    "@tanstack/react-router-with-query": "^1.95.1",
    "@tanstack/react-start": "^1.95.1",
    "@tanstack/router-devtools": "^1.95.1",
    "@tanstack/router-plugin": "^1.95.1",
    "@tanstack/react-query": "^5.62.0",
    "drizzle-orm": "^0.36.4",
    "jose": "^5.9.6",
    "marked": "^14.1.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vinxi": "^0.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251201.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "autoprefixer": "^10.4.20",
    "better-sqlite3": "^11.7.0",
    "drizzle-kit": "^0.28.1",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.2",
    "vite": "^6.0.1",
    "vitest": "^2.1.8",
    "wrangler": "^3.91.0"
  },
  "engines": {
    "node": ">=20"
  }
}
