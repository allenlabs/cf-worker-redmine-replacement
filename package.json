{
  "name": "cf-worker-redmine-replacement",
  "version": "0.1.0",
  "private": true,
  "description": "Redmine-style project management built on TanStack Start + TanStack Router, deployed on Cloudflare Workers.",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply redmine --local",
    "db:migrate": "wrangler d1 migrations apply redmine --remote",
    "db:seed:local": "wrangler d1 execute redmine --local --file=./drizzle/seed.sql",
    "db:seed": "wrangler d1 execute redmine --remote --file=./drizzle/seed.sql",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --project=node --project=jsdom --coverage",
    "test:workers": "vitest run --project=workers"
  },
  "dependencies": {
    "@tanstack/react-query": "5.100.11",
    "@tanstack/react-router": "1.170.6",
    "@tanstack/react-router-with-query": "1.130.17",
    "@tanstack/react-start": "1.168.9",
    "@testing-library/dom": "^10.4.0",
    "drizzle-orm": "0.45.2",
    "jose": "6.2.3",
    "marked": "18.0.4",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.2",
    "@cloudflare/vitest-pool-workers": "0.16.7",
    "@cloudflare/workers-types": "4.20260521.1",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/router-devtools": "1.167.0",
    "@tanstack/router-plugin": "1.168.9",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.5.2",
    "@types/better-sqlite3": "7.6.13",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.7",
    "autoprefixer": "10.5.0",
    "better-sqlite3": "12.10.0",
    "drizzle-kit": "0.31.10",
    "jsdom": "29.1.1",
    "postcss": "8.5.15",
    "tailwindcss": "4.3.0",
    "typescript": "5.7.2",
    "vite": "8.0.14",
    "vitest": "4.1.7",
    "wrangler": "4.93.0"
  },
  "engines": {
    "node": ">=20"
  }
}
