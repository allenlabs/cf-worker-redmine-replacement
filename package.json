{
  "name": "cf-worker-apps",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo of Cloudflare Workers apps — each app may ship multiple workers (Queue / Workflow / cron / SSR / …).",
  "workspaces": [
    "apps/*",
    "packages/*",
    "tests/e2e"
  ],
  "scripts": {
    "install:all": "npm install",
    "test": "npm run -ws --if-present test",
    "test:coverage": "npm run -ws --if-present test:coverage",
    "typecheck": "npm run -ws --if-present typecheck",
    "test:pm": "npm run -w @cf-worker-apps/project-management test",
    "test:url": "npm run -w @cf-worker-apps/url-shortener test",
    "test:relay": "npm run -w @cf-worker-apps/webhook-relay test",
    "test:notion": "npm run -w @cf-worker-apps/notion-gateway test",
    "test:inbox": "npm run -w @cf-worker-apps/inbox test",
    "test:focus": "npm run -w @cf-worker-apps/focus test",
    "test:today": "npm run -w @cf-worker-apps/today test",
    "test:context": "npm run -w @cf-worker-apps/context test",
    "test:concierge": "npm run -w @cf-worker-apps/concierge test",
    "test:read-later": "npm run -w @cf-worker-apps/read-later test",
    "test:stash": "npm run -w @cf-worker-apps/stash test",
    "test:nudge": "npm run -w @cf-worker-apps/nudge test",
    "test:journal": "npm run -w @cf-worker-apps/journal test",
    "test:intent": "npm run -w @cf-worker-apps/intent test",
    "test:cli": "npm run -w @allenlabs/cli test",
    "test:e2e": "npm run -w @cf-worker-apps/e2e test",
    "e2e:cleanup": "npm run -w @cf-worker-apps/e2e cleanup",
    "dev:pm": "npm run -w @cf-worker-apps/project-management dev",
    "dev:url": "npm run -w @cf-worker-apps/url-shortener dev",
    "dev:relay:ingest": "npm run -w @cf-worker-apps/webhook-relay dev:ingest",
    "dev:relay:relay": "npm run -w @cf-worker-apps/webhook-relay dev:relay",
    "dev:notion:api": "npm run -w @cf-worker-apps/notion-gateway dev:api",
    "dev:notion:web": "npm run -w @cf-worker-apps/notion-gateway dev:web",
    "dev:inbox": "npm run -w @cf-worker-apps/inbox dev",
    "dev:inbox:api": "npm run -w @cf-worker-apps/inbox dev:api",
    "dev:focus": "npm run -w @cf-worker-apps/focus dev",
    "dev:focus:api": "npm run -w @cf-worker-apps/focus dev:api",
    "dev:today": "npm run -w @cf-worker-apps/today dev",
    "dev:context": "npm run -w @cf-worker-apps/context dev",
    "dev:context:api": "npm run -w @cf-worker-apps/context dev:api",
    "dev:concierge": "npm run -w @cf-worker-apps/concierge dev",
    "dev:concierge:api": "npm run -w @cf-worker-apps/concierge dev:api",
    "dev:concierge:cron": "npm run -w @cf-worker-apps/concierge dev:cron",
    "dev:read-later": "npm run -w @cf-worker-apps/read-later dev",
    "dev:read-later:api": "npm run -w @cf-worker-apps/read-later dev:api",
    "dev:stash": "npm run -w @cf-worker-apps/stash dev",
    "dev:stash:api": "npm run -w @cf-worker-apps/stash dev:api",
    "dev:nudge": "npm run -w @cf-worker-apps/nudge dev",
    "dev:nudge:api": "npm run -w @cf-worker-apps/nudge dev:api",
    "dev:nudge:cron": "npm run -w @cf-worker-apps/nudge dev:cron",
    "dev:journal": "npm run -w @cf-worker-apps/journal dev",
    "dev:journal:api": "npm run -w @cf-worker-apps/journal dev:api",
    "dev:intent": "npm run -w @cf-worker-apps/intent dev",
    "dev:intent:api": "npm run -w @cf-worker-apps/intent dev:api"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "@tanstack/router-core": "1.171.6"
  }
}
