{
  "name": "@allenlabs/cli",
  "version": "0.3.0",
  "description": "Zero-friction CLI for the Allen Labs ADHD-developer SaaS suite (inbox, focus, context, …).",
  "type": "module",
  "bin": {
    "al": "./dist/bin/al.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "link": "npm run build && npm link",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@vitest/coverage-v8": "4.1.7",
    "typescript": "5.7.2",
    "vitest": "4.1.7"
  },
  "engines": {
    "node": ">=18"
  }
}
