{
  "name": "@allenlabs/i18n",
  "version": "0.1.0",
  "description": "Shared lightweight i18n (en/ko) for the Allen Labs Cloudflare Workers suite.",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./react": "./src/react.tsx",
