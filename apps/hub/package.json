{
  "name": "@cf-worker-apps/hub",
  "version": "0.1.0",
  "private": true,
  "description": "Reverse-proxy + nav shell.  Home page with a left-rail nav grid of cards linking to every Allen Labs app.  No DB, no API — just navigation.",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "deploy:web": "npm run build && wrangler deploy --config workers/web/wrangler.toml",
    "deploy": "npm run deploy:web",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --project=node --project=jsdom --coverage"
  },
  "dependencies": {
    "@allenlabs/i18n": "*",
    "@microlabs/otel-cf-workers": "^1.0.0-rc.52",
    "@tanstack/react-query": "5.100.11",
    "@tanstack/react-router": "1.170.8",
    "@tanstack/react-router-with-query": "1.130.17",
    "@tanstack/react-start": "^1.168.9",
    "@tanstack/router-core": "1.171.6",
    "jose": "6.2.3",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260521.1",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/router-cli": "1.167.8",
    "@tanstack/router-plugin": "1.168.9",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.5.2",
    "@types/node": "^22.19.19",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.7",
    "jsdom": "29.1.1",
    "tailwindcss": "4.3.0",
    "typescript": "5.7.2",
    "vite": "8.0.14",
    "vitest": "4.1.7",
    "wrangler": "4.93.0"
  },
  "engines": {
    "node": ">=20"
  }
}
